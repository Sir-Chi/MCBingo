{
  "type": "minecraft:multi_action",
  "title": {
    "text": "All Recipes Unlocked",
    "color": "gold",
    "underlined": true
  },
  "external_title": "All Recipes Unlocked",
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "All players get all the recipes unlocked and viewable in the recipe book for the duration of the game.",
        "color": "aqua"
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If ON, all the recipes are unlocked at the start of the game for all players."
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If OFF,  all players will gain recipes as normal just by playing the game."
      },
      "width": 300
    }
  ],
  "pause": false,
  "after_action": "none",
  "exit_action": {
    "label": "Back",
    "action": {
      "type": "show_dialog",
      "dialog": "bingo:game_setup_dialog"
    }
  },
  "actions": [
    {
      "label": {
        "text": "ON",
        "color": "green"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_configs/all_recipes_unlocked_on"
      }
    },
    {
      "label": {
        "text": "OFF",
        "color": "red"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_configs/all_recipes_unlocked_off"
      }
    }
  ]
}