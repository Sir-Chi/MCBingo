{
  "type": "minecraft:multi_action",
  "title": {
    "text": "5-In-A-Line",
    "color": "gold",
    "underlined": true
  },
  "external_title": "5-In-A-Line",
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "This is the most basic Bingo mode. To win get 5 items in a row, column, or diagonal.",
        "color": "aqua"
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If ON, the game will automatically end if a player obtains 5-In-A-Line Bingo. "
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If OFF, the game will not automatically end and will continue to be able to be played even when a player obtains 5-In-A-Line Bingo."
      },
      "width": 300
    }
  ],
  "pause": false,
  "after_action": "none",
  "exit_action": {
    "label": "Back",
    "action": {
      "type": "show_dialog",
      "dialog": "bingo:game_setup_dialog"
    }
  },
  "actions": [
    {
      "label": {
        "text": "ON",
        "color": "green"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_modes/5_in_a_line_on"
      }
    },
    {
      "label": {
        "text": "OFF",
        "color": "red"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_modes/5_in_a_line_off"
      }
    }
  ]
}