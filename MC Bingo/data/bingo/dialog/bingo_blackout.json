{
  "type": "minecraft:multi_action",
  "title": {
    "text": "Blackout",
    "color": "gold",
    "underlined": true
  },
  "external_title": "Blackout",
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "For extra challenge, in this mode you will need to obtain all 25 items on the Bingo card.",
        "color": "aqua"
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If ON, the game will automatically end after a player obtains all 25 items on the Bingo card."
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If OFF, the game will not automatically end and will continue to be able to be played even after a player obtains all 25 items on the Bingo card."
      },
      "width": 300
    }
  ],
  "pause": false,
  "after_action": "none",
  "exit_action": {
    "label": "Back",
    "action": {
      "type": "show_dialog",
      "dialog": "bingo:game_setup_dialog"
    }
  },
  "actions": [
    {
      "label": {
        "text": "ON",
        "color": "green"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_modes/blackout_on"
      }
    },
    {
      "label": {
        "text": "OFF",
        "color": "red"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_modes/blackout_off"
      }
    }
  ]
}