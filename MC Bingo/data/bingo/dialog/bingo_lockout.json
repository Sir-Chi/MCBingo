{
  "type": "minecraft:multi_action",
  "title": {
    "text": "Lockout",
    "color": "gold",
    "underlined": true
  },
  "external_title": "Lockout",
  "body": [
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "Once one team obtains an item, claiming a square on the Bingo card, no other team can get that square. First to Bingo or to get a high score wins the game! (The required high score is based on how many teams are playing.)",
        "color": "aqua"
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If ON, lockout mode will be activated."
      },
      "width": 300
    },
    {
      "type": "minecraft:plain_message",
      "contents": {
        "text": "If OFF, lockout mode will be deactivated."
      },
      "width": 300
    }
  ],
  "pause": false,
  "after_action": "none",
  "exit_action": {
    "label": "Back",
    "action": {
      "type": "show_dialog",
      "dialog": "bingo:game_setup_dialog"
    }
  },
  "actions": [
    {
      "label": {
        "text": "ON",
        "color": "green"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_modes/lockout_on"
      }
    },
    {
      "label": {
        "text": "OFF",
        "color": "red"
      },
      "action": {
        "type": "run_command",
        "command": "function bingo:lobby/game_modes/lockout_off"
      }
    }
  ]
}