# Ran by every item detection advancement as player who got advancement

# Get player's team
$execute as @s[team=blue] run return run function bingo:universal/special_items/item_active_check_special {category:'$(category)', difficulty:'$(difficulty)', name:'$(name)', item:'$(item)', special_item:'$(special_item)', team:'blue', team_name:'itemsBlue', team_color:'blue'}
